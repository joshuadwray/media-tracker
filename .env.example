# Copy to .env (or export in your shell / set as GitHub Actions secrets).
# The tracker reads plain environment variables — if you use a .env file
# locally, load it with `set -a; source .env; set +a` before running.

# ntfy.sh phone push. Install the ntfy app, subscribe to an unguessable
# topic name, and put that name here. Anyone who knows the topic can
# read/post to it on the public server, so treat it like a password.
NTFY_TOPIC=

# Optional overrides:
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=
